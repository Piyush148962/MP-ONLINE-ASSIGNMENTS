using System;
using System.Collections.Generic;
using System.Linq;
using System.Threading.Tasks;
using Microsoft.AspNetCore.Mvc;
using Microsoft.AspNetCore.Mvc.RazorPages;
using Microsoft.AspNetCore.Mvc.Rendering;
using Razore_PageModel_Demo.Data;
using Razore_PageModel_Demo.Models;
 
namespace Razore_PageModel_Demo.Pages.Prod
{
   public class CreateModel : PageModel
   {
       private readonly Razore_PageModel_Demo.Data.ProductDataContext _context;
 
       public CreateModel(Razore_PageModel_Demo.Data.ProductDataContext context)
       {
          _context = context;
       }
 
       public IActionResult OnGet()
       {
           return Page();
       }
 
      [BindProperty]
       public Product Product { get; set; } = default!;
      
 
       // To protect from overposting attacks, see https://aka.ms/RazorPagesCRUD
       public async Task<IActionResult> OnPostAsync()
       {
         if (!ModelState.IsValid || _context.Product == null || Product == null)
           {
              return Page();
           }
 
          _context.Product.Add(Product);
           await _context.SaveChangesAsync();
 
           return RedirectToPage("./Index");
       }
   }
}
 
 
