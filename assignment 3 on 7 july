Creates following Code
 
using System;
using System.Collections.Generic;
using System.Linq;
using System.Threading.Tasks;
using Microsoft.AspNetCore.Mvc;
using Microsoft.AspNetCore.Mvc.RazorPages;
using Microsoft.EntityFrameworkCore;
using Razore_PageModel_Demo.Data;
using Razore_PageModel_Demo.Models;
 
namespace Razore_PageModel_Demo.Pages.Prod
{
   public class IndexModel : PageModel
   {
       private readonly Razore_PageModel_Demo.Data.Razore_PageModel_DemoContext _context;
 
       public IndexModel(Razore_PageModel_Demo.Data.Razore_PageModel_DemoContext context)
       {
          _context = context;
       }
 
       public IList<Product> Product { get;set; } = default!;
 
       public async Task OnGetAsync()
       {
           if (_context.Product != null)
           {
              Product = await _context.Product.ToListAsync();
           }
       }
   }
}
 
 
 
 
 
 
 
 
 
 
 
 
 
 
