Create ‘DataContext’ class as follows
 
using System;
using System.Collections.Generic;
using System.Linq;
using System.Threading.Tasks;
using Microsoft.EntityFrameworkCore;
using Razore_PageModel_Demo.Models;
 
namespace Razore_PageModel_Demo.Data
{
   public class ProductDataContext : DbContext
   {
       public ProductDataContext (DbContextOptions<ProductDataContext> options)
           : base(options)
       {
       }
 
       public DbSet<Razore_PageModel_Demo.Models.Product> Product { get; set; } = default!;
   }
}
 
 
 
 
Create Design Factory
 
using Microsoft.EntityFrameworkCore;
using Microsoft.EntityFrameworkCore.Design;
 
namespace CRUDRazorDemo.Models
{
   public class ProductDataContextFactory : IDesignTimeDbContextFactory<ProductDataContext>
   {
       public ProductDataContext CreateDbContext(string[] args)
       {
          var optionsBuilder = new DbContextOptionsBuilder<ProductDataContext>();
 
          optionsBuilder.UseSqlServer(
              "Server=.;Database=CRUDDB;Trusted_Connection=True;TrustServerCertificate=True;");
 
          return new ProductDataContext(optionsBuilder.Options);
       }
   }
}
 
