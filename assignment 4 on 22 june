1. FizzBuzz Variant with Primes (1 to 50)

using System;

public class NumberRulesDemo
{
    public static void PrintNumbers()
    {
        for (int i = 1; i <= 50; i++)
        {
            // Rule 3: Divisible by both 3 and 5
            if (i % 3 == 0 && i % 5 == 0)
            {
                Console.WriteLine("3-5");
            }
            // Rule 4: Prime numbers
            else if (IsPrime(i))
            {
                Console.WriteLine("Prime");
            }
            // Rule 1: Divisible by 3
            else if (i % 3 == 0)
            {
                Console.WriteLine("3");
            }
            // Rule 2: Divisible by 5
            else if (i % 5 == 0)
            {
                Console.WriteLine("5");
            }
            // Otherwise, print the number
            else
            {
                Console.WriteLine(i);
            }
        }
    }

    // Helper method to check if a number is prime
    private static bool IsPrime(int number)
    {
        if (number <= 1) return false;
        if (number == 2) return true;
        if (number % 2 == 0) return false;

        var boundary = (int)Math.Floor(Math.Sqrt(number));

        for (int i = 3; i <= boundary; i += 2)
        {
            if (number % i == 0) return false;
        }

        return true;
    }
}


2. Group Anagrams from a Given List


using System;
using System.Collections.Generic;
using System.Linq;

public class AnagramGrouper
{
    public static void GroupAndPrintAnagrams(List<string> words)
    {
        // Dictionary where Key = sorted word, Value = list of anagrams
        Dictionary<string, List<string>> anagramGroups = new Dictionary<string, List<string>>();

        foreach (string word in words)
        {
            // Normalize to lowercase, convert to char array, sort, and re-string
            char[] chars = word.ToLower().ToCharArray();
            Array.Sort(chars);
            string sortedKey = new string(chars);

            // Group the word under its sorted key
            if (!anagramGroups.ContainsKey(sortedKey))
            {
                anagramGroups[sortedKey] = new List<string>();
            }
            anagramGroups[sortedKey].Add(word);
        }

        // Print results
        Console.WriteLine("\n--- Anagram Groups ---");
        foreach (var group in anagramGroups.Values)
        {
            Console.WriteLine($"[{string.Join(", ", group)}]");
        }
    }
}


3. Running Both Together

public class Program
{
    public static void Main()
    {
        Console.WriteLine("--- Number Rules Output (1 to 50) ---");
        NumberRulesDemo.PrintNumbers();

        // Testing Anagram grouping
        List<string> sampleWords = new List<string> { "eat", "tea", "tan", "ate", "nat", "bat", "silent", "listen" };
        AnagramGrouper.GroupAndPrintAnagrams(sampleWords);
    }
