CREATE PROCEDURE sp_ProcessTransaction
    @SenderAcc INT,
    @ReceiverAcc INT,
    @Amount DECIMAL(18,2),
    @StatusMessage VARCHAR(250) OUTPUT
AS
BEGIN
    SET NOCOUNT ON;
    
    -- Start the atomic unit transaction
    BEGIN TRANSACTION;

    BEGIN TRY
        -- 1. Verify Sender Account Exists and Has Enough Funds
        IF NOT EXISTS (SELECT 1 FROM Accounts WHERE AccountNumber = @SenderAcc)
        BEGIN
            SET @StatusMessage = 'Transaction Failed: Sender account does not exist.';
            ROLLBACK TRANSACTION;
            RETURN;
        END

        IF (SELECT Balance FROM Accounts WHERE AccountNumber = @SenderAcc) < @Amount
        BEGIN
            SET @StatusMessage = 'Transaction Failed: Insufficient funds in Sender account.';
            ROLLBACK TRANSACTION;
            RETURN;
        END

        -- 2. Verify Receiver Account Exists
        IF NOT EXISTS (SELECT 1 FROM Accounts WHERE AccountNumber = @ReceiverAcc)
        BEGIN
            SET @StatusMessage = 'Transaction Failed: Receiver account does not exist.';
            ROLLBACK TRANSACTION;
            RETURN;
        END

        -- 3. Deduct from Sender
        UPDATE Accounts 
        SET Balance = Balance - @Amount 
        WHERE AccountNumber = @SenderAcc;

        -- 4. Add to Receiver
        UPDATE Accounts 
        SET Balance = Balance + @Amount 
        WHERE AccountNumber = @ReceiverAcc;

        -- Commit changes if all operations succeed
        COMMIT TRANSACTION;
        SET @StatusMessage = 'Transaction Completed Successfully.';
    END TRY
    BEGIN CATCH
        -- Rollback changes if any system error occurs
        ROLLBACK TRANSACTION;
        SET @StatusMessage = 'Transaction Failed: Internal Error - ' + ERROR_MESSAGE();
    END CATCH
END;
 
