1. Grouping Anagrams
using System;
using System.Collections.Generic;
using System.Linq;

public class AnagramGrouper
{
    public static void GroupAndPrintAnagrams(List<string> words)
    {
        // Dictionary where Key = sorted word, Value = list of anagrams
        Dictionary<string, List<string>> anagramGroups = new Dictionary<string, List<string>>();

        foreach (string word in words)
        {
            // Normalize by converting to lowercase, then sort the characters
            char[] chars = word.ToLower().ToCharArray();
            Array.Sort(chars);
            string sortedKey = new string(chars);

            // Add the original word to its matching sorted group
            if (!anagramGroups.ContainsKey(sortedKey))
            {
                anagramGroups[sortedKey] = new List<string>();
            }
            anagramGroups[sortedKey].Add(word);
        }

        // Print the grouped anagrams
        Console.WriteLine("--- Anagram Groups ---");
        foreach (var group in anagramGroups.Values)
        {
            Console.WriteLine($"[{string.Join(", ", group)}]");
        }
    }
}

