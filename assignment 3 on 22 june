## 2. Number Guessing Challenge
This program generates a random number between 1 and 100, then guides the player to the answer with "Too high" or "Too low" hints, tracking their total attempts.

```csharp
using System;

public class GuessingGame
{
    public static void StartChallenge()
    {
        Random random = new Random();
        int targetNumber = random.Next(1, 101); // Random number between 1 and 100
        int userGuess = 0;
        int attempts = 0;

        Console.WriteLine("=====================================");
        Console.WriteLine("  Welcome to the Guessing Challenge! ");
        Console.WriteLine("=====================================");
        Console.WriteLine("I am thinking of a number between 1 and 100.");

        // Game loop
        while (userGuess != targetNumber)
        {
            Console.Write("\nEnter your guess: ");
            string input = Console.ReadLine();

            // Validate that the input is a valid integer
            if (!int.TryParse(input, out userGuess))
            {
                Console.WriteLine("Please enter a valid number.");
                continue;
            }

            attempts++;

            if (userGuess < targetNumber)
            {
                Console.WriteLine("Too low! Try a higher number.");
            }
            else if (userGuess > targetNumber)
            {
                Console.WriteLine("Too high! Try a lower number.");
            }
            else
            {
                Console.WriteLine($"\n🎉 Congratulations! You guessed it right!");
                Console.WriteLine($"The number was {targetNumber}. It took you {attempts} attempts.");
            }
        }
    }
}


