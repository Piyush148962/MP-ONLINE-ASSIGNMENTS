using System;

public class Student
{
    public int StudentId { get; set; } // Yeh apne aap Primary Key (Identity) ban jayega
    public string FirstName { get; set; }
    public string LastName { get; set; }
    public string Email { get; set; }
    public DateTime EnrollmentDate { get; set; } = DateTime.Now;
}


using Microsoft.EntityFrameworkCore;

public class SchoolContext : DbContext
{
    public DbSet<Student> Students { get; set; }

    protected override void OnConfiguring(DbContextOptionsBuilder optionsBuilder)
    {
        // Apni SQL Server ki connection string yahan daalein
        optionsBuilder.UseSqlServer(@"Server=YOUR_SERVER_NAME;Database=SchoolEFCoreDB;Trusted_Connection=True;TrustServerCertificate=True;");
    }
}



