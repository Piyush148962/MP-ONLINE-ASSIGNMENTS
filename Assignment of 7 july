using System;
using System.Linq;

class Program
{
    static void Main()
    {
        using (var db = new SchoolContext())
        {
            // 1. Naya Student Add Karna
            Console.WriteLine("Adding a new student...");
            var newStudent = new Student 
            { 
                FirstName = "Kamal", 
                LastName = "Sharma", 
                Email = "kamal.efcore@example.com" 
            };
            
            db.Students.Add(newStudent);
            db.SaveChanges(); // Yeh line data save kar degi
            Console.WriteLine("Student saved successfully!\n");

            // 2. Students Ki List Show Karna
            Console.WriteLine("--- Registered Students List ---");
            var studentList = db.Students.ToList();
            
            foreach (var student in studentList)
            {
                Console.WriteLine($"ID: {student.StudentId} | Name: {student.FirstName} {student.LastName} | Email: {student.Email}");
            }
        }
    }
}



